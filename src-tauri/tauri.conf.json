{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalOffice",
  "version": "0.16.2",
  "identifier": "com.localoffice.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalOffice",
        "width": 1100,
        "height": 740,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline' blob:",
        "img-src": "'self' data: blob: https:",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:8088 blob: ws://localhost:1420"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "externalBin": ["binaries/pandoc"],
    "resources": ["binaries/llama/*"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "txt", "html", "htm", "docx", "odt"],
        "name": "Documento",
        "description": "Documento de texto do LocalOffice",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
