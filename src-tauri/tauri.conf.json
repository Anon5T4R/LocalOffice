{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalOffice",
  "version": "0.6.1",
  "identifier": "com.taylor.localoffice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalOffice",
        "width": 1100,
        "height": 740,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/pandoc"],
    "resources": ["binaries/llama/*"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "txt", "html", "htm", "docx", "odt"],
        "name": "Documento",
        "description": "Documento de texto do LocalOffice",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
